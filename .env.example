# Copy this file to .env and adjust as needed. .env is gitignored.
# docker-compose.yml reads these automatically.

# --- Rails app container ---
RAILS_ENV=development
# Host port the Rails server is published on (container always listens on 3000)
APP_PORT=3000
# Hostname the app uses to reach MySQL (the "db" compose service)
DB_HOST=db

COINGECKO_API_KEY=
